# Copy this file to .env and fill in the values before running in production.

# REQUIRED in production: set this to a long random string (e.g. `openssl rand -hex 32`)
# If left unset the server falls back to a hardcoded dev secret — never use that in production.
JWT_SECRET=

# Optional: change the port the server listens on (default: 3001)
# PORT=3001
